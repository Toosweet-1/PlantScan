@model PlantScan.Models.PlantResult
@{
    ViewData["Title"] = "Identification Result";
}

<div class="bg-slideshow">
    <div class="bg-slide active" style="background-image:url('https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=1600&q=80')"></div>
    <div class="bg-slide" style="background-image:url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1600&q=80')"></div>
    <div class="bg-slide" style="background-image:url('https://images.unsplash.com/photo-1477414348463-c0eb7f1359b6?w=1600&q=80')"></div>
    <div class="bg-slide" style="background-image:url('https://images.unsplash.com/photo-1502082553048-f009c37129b9?w=1600&q=80')"></div>
    <div class="bg-overlay"></div>
</div>

<section class="result-section">
    <div class="result-card">
        <div class="result-image-col">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.PlantName" class="result-image" />
            }
            else
            {
                <div class="result-image-placeholder">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                        <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z" opacity="0.3"/>
                        <path d="M8 12s1.5-4 4-4 4 4 4 4"/>
                    </svg>
                </div>
            }
            <div class="confidence-block">
                <div class="confidence-header">
                    <p class="confidence-label">MATCH CONFIDENCE</p>
                    <p class="confidence-value">@((int)(Model.Confidence * 100))%</p>
                </div>
                <div class="confidence-bar-track">
                    <div class="confidence-bar-fill" style="--conf: @((int)(Model.Confidence * 100))%"></div>
                </div>
            </div>
        </div>

        <div class="result-info-col">
            <p class="result-eyebrow">Identified Plant</p>
            <h1 class="result-name">@Model.PlantName</h1>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="info-block">
                    <h3 class="info-title">Description</h3>
                    <p class="info-text">@Model.Description</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.CommonUses))
            {
                <div class="info-block">
                    <h3 class="info-title">Common Uses</h3>
                    <p class="info-text">@Model.CommonUses</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Warnings))
            {
                <div class="info-block warning-block">
                    <h3 class="info-title warning-title">⚠ Warnings</h3>
                    <p class="info-text">@Model.Warnings</p>
                </div>
            }

            <a href="/" class="btn-primary scan-again">SCAN ANOTHER PLANT</a>
        </div>
    </div>
</section>